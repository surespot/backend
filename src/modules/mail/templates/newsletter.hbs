<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{subject}}</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
      background-color: #FFF8E7;
    }
    .container {
      background-color: #FFFFFF;
      border-radius: 8px;
      padding: 40px;
      box-shadow: 0 2px 8px rgba(212, 175, 55, 0.15);
      border-top: 4px solid #D4AF37;
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .logo {
      font-size: 28px;
      font-weight: bold;
      color: #D4AF37;
      margin-bottom: 10px;
    }
    .content {
      margin: 20px 0;
    }
    .content p {
      margin: 0 0 1em 0;
    }
    .footer {
      text-align: center;
      margin-top: 30px;
      padding-top: 20px;
      border-top: 1px solid #F5F5DC;
      color: #666;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo">Surespot Eatery</div>

    </div>

    <div class="content">
      <p>Hello {{firstName}},</p>
      {{{body}}}
      <p>Thank you for being part of the SureSpot community!</p>
    </div>

    <div class="footer">
      <p>You received this email because you are subscribed to SureSpot updates.</p>
      <p>&copy; {{currentYear}} SureSpot. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
