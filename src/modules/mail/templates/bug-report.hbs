<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Surespot Bug Report</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
    .container { background-color: #fff; border-radius: 8px; padding: 30px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-top: 4px solid #D4AF37; }
    .header { text-align: center; margin-bottom: 24px; }
    .logo { font-size: 24px; font-weight: bold; color: #D4AF37; }
    .title { font-size: 20px; font-weight: 600; color: #333; margin: 8px 0; }
    .section { margin: 20px 0; padding: 16px; background: #f8f9fa; border-radius: 6px; }
    .label { font-weight: 600; color: #666; font-size: 12px; text-transform: uppercase; margin-bottom: 4px; }
    .value { margin: 0; }
    .attachments { margin-top: 8px; }
    .attachment-link { display: block; margin: 6px 0; color: #2563eb; text-decoration: none; word-break: break-all; }
    .attachment-link:hover { text-decoration: underline; }
    .footer { margin-top: 24px; padding-top: 16px; border-top: 1px solid #eee; font-size: 12px; color: #666; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo">SureSpot</div>
      <h1 class="title">Surespot Bug Report</h1>
    </div>

    <div class="section">
      <div class="label">Report ID</div>
      <p class="value">{{reportId}}</p>
    </div>

    <div class="section">
      <div class="label">Submitted by</div>
      <p class="value">{{submitterName}} ({{submitterRole}})</p>
      <p class="value">Email: {{submitterEmail}}</p>
      <p class="value">Phone: {{submitterPhone}}</p>
      <p class="value">Date: {{submittedAt}}</p>
    </div>

    {{#if title}}
    <div class="section">
      <div class="label">Title</div>
      <p class="value">{{title}}</p>
    </div>
    {{/if}}

    <div class="section">
      <div class="label">Issue Type</div>
      <p class="value">{{issueType}}</p>
    </div>

    {{#if areaAffected}}
    <div class="section">
      <div class="label">Area Affected</div>
      <p class="value">{{areaAffected}}</p>
    </div>
    {{/if}}

    <div class="section">
      <div class="label">Description</div>
      <p class="value">{{description}}</p>
    </div>

    {{#if stepsToReproduce}}
    <div class="section">
      <div class="label">Steps to Reproduce</div>
      <p class="value" style="white-space: pre-wrap;">{{stepsToReproduce}}</p>
    </div>
    {{/if}}

    {{#if hasAttachments}}
    <div class="section">
      <div class="label">Attachments / Media</div>
      <div class="attachments">
        {{#each attachmentUrls}}
        <a href="{{this}}" class="attachment-link" target="_blank">View media {{@index}}</a>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <div class="footer">
      <p>This bug report was forwarded from the SureSpot admin dashboard.</p>
      <p>&copy; {{currentYear}} SureSpot. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
