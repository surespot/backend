# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/surespot
MONGODB_DB_NAME=surespot

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_RESEND_SECONDS=30
OTP_MAX_ATTEMPTS=5

# Storage Provider: cloudinary | s3 (default: cloudinary)
STORAGE_PROVIDER=cloudinary

# Cloudinary Configuration (when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Image resize (Sharp) - applied before upload for JPEG, PNG, WebP
# IMAGE_MAX_WIDTH=1920
# IMAGE_MAX_HEIGHT=1920
# IMAGE_QUALITY=85

# S3 Configuration (when STORAGE_PROVIDER=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=surespot-uploads
# S3_PUBLIC_URL_PREFIX=https://surespot-uploads.s3.us-east-1.amazonaws.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=surespot_redis_password

# Expo Push Notifications (optional, for higher rate limits)
EXPO_ACCESS_TOKEN=

# Email Configuration (SMTP)
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_USER=admin@surespot.ng
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Surespot Eatery

# SMS Provider: bulksms | termii (default: bulksms)
SMS_PROVIDER=bulksms

# BulkSMS Nigeria (when SMS_PROVIDER=bulksms)
SMS_API_URL=https://www.bulksmsnigeria.com/api/v2/sms
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=SureSpot

# Termii (when SMS_PROVIDER=termii)
# TERMII_API_KEY=your-termii-api-key
# TERMII_BASE_URL=https://api.ng.termii.com

# Payment Configuration (Paystack)
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# Integrations test: GET /integrations-test (admin-only, uses above config)

# Admin Bootstrap - Master code to authorize first 3 admin account creations
ADMIN_BOOTSTRAP_MASTER_CODE=your-secret-master-code-here